  "lspServers": {
    "typescript": {
      "command": "typescript-language-server",
      "args": ["--stdio"],
      "fileExtensions": {
        ".ts": "typescript",
        ".tsx": "typescript"
      }
    },
    "python": {
      "command": "backend/venv/Scripts/pylsp",
      "args": [],
      "fileExtensions": {
        ".py": "python"
      }
    }
  }
}


